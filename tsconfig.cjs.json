{
  "extends": "./tsconfig.esm.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "es2020",
    "skipLibCheck": true,
    "outDir": "./dist/cjs",
    "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "@mysten/sui/*": ["node_modules/@mysten/sui/dist/cjs/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/__tests__"]
}
