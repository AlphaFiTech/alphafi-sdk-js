{
  "name": "@alphafi/alphafi-sdk",
  "version": "1.0.0",
  "description": "AlphaFi SDK for JavaScript",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:cjs && npm run build:esm",
    "build:esm": "tsc --project tsconfig.esm.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "build:cjs": "tsc --project tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "lint": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "jest --config jest.config.cjs.js",
    "docs": "typedoc"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "sui",
    "defi",
    "alphafi",
    "sdk",
    "blockchain",
    "yield",
    "lending",
    "liquidity"
  ],
  "author": "AlphaFi",
  "license": "ISC",
  "dependencies": {
    "@alphafi/alphalend-sdk": "^1.1.27",
    "@alphafi/stsui-sdk": "^0.0.23",
    "@apollo/client": "^4.0.11",
    "@cetusprotocol/aggregator-sdk": "^1.4.2",
    "@cetusprotocol/cetus-sui-clmm-sdk": "5.4.0",
    "bech32": "^2.0.0",
    "bn.js": "^5.2.2",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.2.3",
    "graphql": "^16.12.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.3.4",
    "tslib": "^2.8.1",
    "tsx": "^4.19.2",
    "typedoc": "^0.28.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.14.0"
  },
  "peerDependencies": {
    "@mysten/sui": "1.45.0"
  }
}
