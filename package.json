{
  "name": "@alphafi/alphafi-sdk",
  "version": "1.0.0",
  "description": "AlphaFi SDK for JavaScript",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:cjs && npm run build:esm",
    "build:esm": "tsc --project tsconfig.esm.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "build:cjs": "tsc --project tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "build:docker": "npm run build",
    "lint": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "jest --config jest.config.cjs.js",
    "test:deposits": "npx tsx scripts/testDeposits.ts",
    "test:deposits:alt": "npx ts-node --esm scripts/testDeposits.ts",
    "test:deposits:simple": "npx tsx scripts/testDeposits.ts",
    "test:deposits:build": "tsc scripts/testDeposits.ts --outDir scripts/build --module esnext --target es2022 --moduleResolution node --esModuleInterop && node scripts/build/testDeposits.js",
    "test:deposits:clean": "NODE_OPTIONS='--no-deprecation --no-warnings' npx ts-node --esm scripts/testDeposits.ts",
    "test:withdraws": "npx tsx scripts/testWithdraws.ts",
    "docs": "typedoc",
    "pre-commit:install": "pre-commit install",
    "pre-commit:run": "pre-commit run --all-files"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@alphafi/alphafi-sdk-upstream": "file:../alphafi-sdk",
    "@alphafi/alphalend-sdk": "^1.1.24",
    "@apollo/client": "^3.11.4",
    "@cetusprotocol/cetus-sui-clmm-sdk": "5.1.6",
    "bech32": "^2.0.0",
    "bn.js": "^5.2.2",
    "decimal.js": "^10.5.0",
    "dotenv": "^16.4.5",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "babel-loader": "^10.0.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsx": "^4.19.2",
    "typedoc": "^0.28.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.14.0"
  },
  "peerDependencies": {
    "@alphafi/stsui-sdk": "^0.0.22",
    "@mysten/sui": "^1.45.0"
  }
}
